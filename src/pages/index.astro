---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import siteInfo from '../data/site-info.json';
---

<Layout title="On A Roll Sushi & Sliders | Windsor, ON">
  <Nav />
  <main>
    <!-- Section 1: Hero -->
    <section class="relative h-[90vh] w-full flex items-center overflow-hidden bg-surface-container-lowest">
      <div class="absolute inset-0 z-0">
        <img alt="Dragon roll with eel sauce" class="w-full h-full object-cover opacity-80 scale-105" src="/images/sushi-plate.jpeg" />
        <div class="absolute inset-0 cinematic-gradient"></div>
      </div>
      <div class="relative z-10 w-full max-w-screen-2xl mx-auto px-8">
        <div class="max-w-4xl">
          <h1 class="font-headline text-[12vw] md:text-[8rem] leading-[0.85] font-black tracking-tighter text-on-surface mb-8">
            ON <span class="text-primary italic text-glow">A</span> ROLL
          </h1>
          <p class="font-body text-xl md:text-2xl text-secondary mb-12 max-w-2xl font-light tracking-wide leading-relaxed">
            Good Food. Good Music. Good People. Good Vibes.
          </p>
          <div class="flex flex-wrap items-center gap-6">
            <a href={siteInfo.orderOnline} target="_blank" rel="noopener noreferrer" class="bg-primary text-on-primary px-8 py-3 md:px-12 md:py-5 font-headline font-bold text-sm md:text-lg tracking-widest hover:brightness-110 transition-all inline-block">
              ORDER NOW
            </a>
            <a href={siteInfo.reserveTable} target="_blank" rel="noopener noreferrer" class="border-2 border-primary text-primary px-8 py-3 md:px-12 md:py-5 font-headline font-bold text-sm md:text-lg tracking-widest hover:bg-primary hover:text-on-primary transition-all inline-block">
              RESERVE A TABLE
            </a>
          </div>
        </div>
      </div>
      <!-- Integrated Skip Section -->
      <div class="absolute bottom-0 right-0 z-20 bg-surface-container-high/40 backdrop-blur-md px-12 py-8 hidden lg:flex items-center gap-8 border-l border-t border-outline-variant/30">
        <div class="flex flex-col">
          <span class="font-label text-primary text-[10px] tracking-[0.4em] uppercase mb-1">Fast Track Delivery</span>
          <h3 class="font-headline text-lg font-bold tracking-tight text-on-surface">Order via Skip The Dishes</h3>
        </div>
        <a class="w-12 h-12 rounded-full border border-primary flex items-center justify-center text-primary hover:bg-primary hover:text-on-primary transition-all" href={siteInfo.orderOnline} target="_blank" rel="noopener noreferrer">
          <span class="material-symbols-outlined">shopping_bag</span>
        </a>
      </div>
    </section>

    <!-- Section 2: Three Pillars -->
    <section class="py-12 md:py-24 px-8 bg-surface">
      <div class="max-w-screen-2xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-y-12 gap-x-12 items-start">
          <!-- Specialty Rolls -->
          <div class="md:col-span-7 group">
            <div class="relative overflow-hidden mb-8 aspect-[16/9]">
              <img alt="Specialty Sushi Rolls" class="w-full h-full object-cover transition-transform duration-700 scale-100 group-hover:scale-105" src="/images/sushi-plate-2.jpeg" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>
            <div class="flex items-baseline gap-6">
              <span class="font-headline text-6xl font-light text-outline-variant italic">01</span>
              <div>
                <h3 class="font-headline text-4xl mb-3 font-bold tracking-tight">Specialty Rolls</h3>
                <p class="text-secondary max-w-md leading-relaxed text-sm">Where traditional technique meets experimental flavor profiles. Architectural masterpieces designed for the palate.</p>
              </div>
            </div>
          </div>
          <!-- Unique Sliders -->
          <div class="md:col-span-5 md:mt-24 group">
            <div class="relative overflow-hidden mb-8 aspect-[4/5]">
              <img alt="Beer and Sliders" class="w-full h-full object-cover transition-transform duration-700 scale-100 group-hover:scale-105" src="/images/beer-sliders.jpeg" />
            </div>
            <div class="flex items-baseline gap-6">
              <span class="font-headline text-6xl font-light text-outline-variant italic">02</span>
              <div>
                <h3 class="font-headline text-4xl mb-3 font-bold tracking-tight">Fusion Sliders</h3>
                <p class="text-secondary leading-relaxed text-sm">Hand-crafted brioche meets premium wagyu and fusion toppings. Small bites with massive sonic impact.</p>
              </div>
            </div>
          </div>
          <!-- Craft Cocktails -->
          <div class="md:col-span-8 md:col-start-3 mt-12 group">
            <div class="relative overflow-hidden mb-8 aspect-[21/9]">
              <img alt="Craft Cocktails and desserts" class="w-full h-full object-cover transition-transform duration-700 scale-100 group-hover:scale-105" src="/images/dessert-cocktail.jpg" />
            </div>
            <div class="flex items-baseline justify-end gap-6 text-right">
              <div class="flex flex-col items-end">
                <h3 class="font-headline text-4xl mb-3 font-bold tracking-tight">Liquid Vinyl</h3>
                <p class="text-secondary max-w-md leading-relaxed text-sm">Liquid art inspired by the rhythm of the night. Infused house-made syrups and rare spirits.</p>
              </div>
              <span class="font-headline text-6xl font-light text-outline-variant italic">03</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 3: About -->
    <section class="py-16 md:py-32 bg-surface-container-low overflow-hidden">
      <div class="max-w-screen-2xl mx-auto px-8 relative">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-16 items-center">
          <div class="md:col-span-5 z-10">
            <span class="font-label text-primary text-xs tracking-[0.5em] uppercase mb-8 block">The Philosophy</span>
            <h2 class="font-headline text-6xl md:text-8xl font-black tracking-tighter mb-12">WE ARE ON A ROLL</h2>
            <div class="space-y-8 font-body text-xl text-secondary leading-relaxed font-light">
              <p>We make specialty sushi rolls, unique sliders and craft cocktails served in a laid-back, friendly atmosphere. With more than 50 years of combined experience, we create food we're proud to serve.</p>
              <p>Every night is a performance. Every dish is a note.</p>
            </div>
            <a href="/about" class="mt-16 group flex items-center gap-4 text-on-surface font-headline font-bold tracking-widest uppercase">
              <span class="border-b-2 border-primary pb-1 group-hover:border-on-surface transition-colors">Learn Our Story</span>
              <span class="material-symbols-outlined text-primary">north_east</span>
            </a>
          </div>
          <div class="md:col-span-7 relative">
            <div class="absolute -top-20 -left-20 w-64 h-64 bg-primary/10 blur-3xl rounded-full"></div>
            <div class="overflow-hidden group">
              <img alt="On A Roll patio" class="w-full aspect-[4/5] object-cover transition-transform duration-700 group-hover:scale-105" src="/images/patio.jpeg" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 4: Signature Dishes -->
    <section class="py-16 md:py-32 px-8 bg-surface-container-lowest">
      <div class="max-w-screen-2xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-end mb-24 gap-8">
          <div class="max-w-2xl">
            <span class="font-label text-primary text-xs tracking-[0.5em] uppercase mb-4 block">The Chef's Selection</span>
            <h2 class="font-headline text-5xl md:text-7xl font-bold tracking-tight">SIGNATURE DISHES</h2>
          </div>
          <p class="font-body text-secondary max-w-xs mb-2">Our most requested creations, meticulously plated and served with a side of soul.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-outline-variant/10">
          <!-- Rocky Raccoon -->
          <div class="bg-surface p-6 md:p-20 group hover:bg-surface-container-low transition-colors duration-500">
            <div class="aspect-square overflow-hidden mb-12">
              <img alt="Rocky Raccoon Roll" class="w-full h-full object-cover scale-100 group-hover:scale-105 transition-transform duration-700" src="/images/rocky-raccoon.jpg" />
            </div>
            <div class="flex justify-between items-start mb-6">
              <h3 class="font-headline text-4xl font-bold">Rocky Raccoon</h3>
              <span class="font-headline text-2xl text-primary">$21</span>
            </div>
            <p class="text-secondary font-light text-lg mb-8 leading-relaxed">Crab tempura, cucumber, topped with eel & avocado. Our most beloved signature roll — a cult classic.</p>
            <a href="/menu" class="text-xs font-label tracking-[0.3em] uppercase text-outline-variant group-hover:text-primary transition-colors">Experience flavor</a>
          </div>
          <!-- Rocket Man -->
          <div class="bg-surface p-6 md:p-20 group hover:bg-surface-container-low transition-colors duration-500">
            <div class="aspect-square overflow-hidden mb-12">
              <img alt="Rocket Man Rainbow Roll" class="w-full h-full object-cover scale-100 group-hover:scale-105 transition-transform duration-700" src="/images/rocket-man.jpg" />
            </div>
            <div class="flex justify-between items-start mb-6">
              <h3 class="font-headline text-4xl font-bold">Rocket Man</h3>
              <span class="font-headline text-2xl text-primary">$22</span>
            </div>
            <p class="text-secondary font-light text-lg mb-8 leading-relaxed">Crab, cucumber, avocado, topped with tuna, salmon, redsnapper & avocado. A rainbow of flavors.</p>
            <a href="/menu" class="text-xs font-label tracking-[0.3em] uppercase text-outline-variant group-hover:text-primary transition-colors">Experience flavor</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 5: Gallery -->
    <section class="py-16 md:py-32 bg-surface">
      <div class="max-w-screen-2xl mx-auto px-8">
        <div class="text-center mb-24">
          <h2 class="font-headline text-5xl md:text-7xl font-black tracking-tighter mb-4">LET THE GOOD TIMES ROLL</h2>
          <p class="font-body text-secondary tracking-widest uppercase text-sm">Follow the vibe @onaroll63</p>
        </div>
        <div id="gallery" class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8">
          <div class="grid gap-4 md:gap-8">
            <img alt="Patio vibes" class="gallery-img w-full aspect-[3/4] object-cover cursor-zoom-in hover:brightness-110 transition-all" src="/images/patio-light.jpeg" />
            <img alt="Friends dining at On A Roll" class="gallery-img w-full aspect-square object-cover cursor-zoom-in hover:brightness-110 transition-all" src="/images/friends-dining.jpg" />
          </div>
          <div class="grid gap-4 md:gap-8 pt-12 md:pt-24">
            <img alt="Greek fries" class="gallery-img w-full aspect-[3/4] object-cover cursor-zoom-in hover:brightness-110 transition-all" src="/images/fries-menu.jpeg" />
            <img alt="Sushi and beer on patio" class="gallery-img w-full aspect-square object-cover cursor-zoom-in hover:brightness-110 transition-all" src="/images/sushi-beer.jpg" />
          </div>
          <div class="grid gap-4 md:gap-8">
            <img alt="Bar interior" class="gallery-img w-full aspect-square object-cover cursor-zoom-in hover:brightness-110 transition-all" src="/images/bar-interior.jpg" />
            <img alt="On A Roll sauce bottles" class="gallery-img w-full aspect-[4/5] object-cover cursor-zoom-in hover:brightness-110 transition-all" src="/images/sauce-bottles.jpg" />
          </div>
          <div class="grid gap-4 md:gap-8 pt-8 md:pt-16">
            <img alt="Dessert and espresso martini" class="gallery-img w-full aspect-square object-cover cursor-zoom-in hover:brightness-110 transition-all" src="/images/dessert-cocktail.jpg" />
            <img alt="Customer enjoying sushi on patio" class="gallery-img w-full aspect-[3/2] object-cover cursor-zoom-in hover:brightness-110 transition-all" src="/images/patio-customer.jpg" />
          </div>
        </div>
      </div>
    </section>

    <!-- Section 6: Live Music -->
    <section class="py-16 md:py-32 bg-surface-container-low relative overflow-hidden">
      <div class="absolute inset-0 opacity-10 pointer-events-none">
        <div class="absolute top-0 left-0 w-full h-full bg-[url('https://www.transparenttextures.com/patterns/pinstriped-dark.png')]"></div>
      </div>
      <div class="max-w-screen-2xl mx-auto px-8 relative z-10">
        <div class="flex flex-col md:flex-row gap-16 items-center">
          <div class="md:w-1/2">
            <span class="font-label text-primary text-xs tracking-[0.5em] uppercase mb-8 block">Every Weekend</span>
            <h2 class="font-headline text-7xl md:text-9xl font-black tracking-tighter mb-8 italic music-glitch transition-all">LIVE ACTS</h2>
            <div class="space-y-6">
              <div class="border-l-4 border-primary pl-6 py-4">
                <p class="text-on-surface font-body text-xl leading-relaxed mb-4">We host live music and entertainment every weekend. From jazz to rock, there's always something happening at On A Roll.</p>
                <p class="text-secondary font-body text-lg leading-relaxed mb-6">Upcoming lineup coming soon.</p>
                <a href={siteInfo.social.instagram} target="_blank" rel="noopener noreferrer" class="text-primary font-headline font-bold text-sm tracking-[0.2em] uppercase border-b border-primary/30 pb-1 hover:border-primary transition-all">Follow @onaroll63 for updates</a>
              </div>
            </div>
          </div>
          <div class="md:w-1/2 grid grid-cols-2 gap-4">
            <div class="overflow-hidden rounded-sm shadow-2xl group">
              <img alt="Live musician singing at On A Roll" class="w-full aspect-[4/5] object-cover transition-transform duration-700 group-hover:scale-105" src="/images/singer.jpg" />
            </div>
            <div class="overflow-hidden rounded-sm shadow-2xl translate-y-12 group">
              <img alt="Bar atmosphere at On A Roll" class="w-full aspect-[4/5] object-cover transition-transform duration-700 group-hover:scale-105" src="/images/bar-interior.jpg" />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox-overlay">
    <span class="lightbox-close">&times;</span>
    <button class="lightbox-nav lightbox-prev" aria-label="Previous image">
      <span class="material-symbols-outlined">chevron_left</span>
    </button>
    <img id="lightbox-img" src="" alt="" />
    <button class="lightbox-nav lightbox-next" aria-label="Next image">
      <span class="material-symbols-outlined">chevron_right</span>
    </button>
    <div class="lightbox-counter" id="lightbox-counter"></div>
  </div>

  <script>
    const images = Array.from(document.querySelectorAll('.gallery-img'));
    const overlay = document.getElementById('lightbox')!;
    const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const counter = document.getElementById('lightbox-counter')!;
    let current = 0;

    function show(index: number) {
      current = (index + images.length) % images.length;
      const img = images[current] as HTMLImageElement;
      lbImg.src = img.src;
      lbImg.alt = img.alt;
      counter.textContent = `${current + 1} / ${images.length}`;
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function hide() {
      overlay.classList.remove('active');
      document.body.style.overflow = '';
    }

    images.forEach((img, i) => img.addEventListener('click', () => show(i)));
    overlay.querySelector('.lightbox-close')!.addEventListener('click', hide);
    overlay.querySelector('.lightbox-prev')!.addEventListener('click', (e) => { e.stopPropagation(); show(current - 1); });
    overlay.querySelector('.lightbox-next')!.addEventListener('click', (e) => { e.stopPropagation(); show(current + 1); });
    overlay.addEventListener('click', (e) => { if (e.target === overlay) hide(); });
    document.addEventListener('keydown', (e) => {
      if (!overlay.classList.contains('active')) return;
      if (e.key === 'Escape') hide();
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });
  </script>
</Layout>
