---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import siteInfo from '../data/site-info.json';

// Image URLs from Appendix B — About page
const heroImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuD6dbkO0YIlSQ2GdbyRBufDCyT7ND7guuxsvJcOShk0q_IIi4n3FnZ02kW04wNudnGWcQW0ch1adLVCVqI0eXlKpP3kBS4s5Gde0oTDif6ouih29mvw14qtfMOy5lSijME3Rh_wS8r6hv_oCU1RIKtHJSQeXKbg-t4Ka3BWHvVpFO5o6Bzst8UO0WgGtWQuq4V6Vr5iadsv9Uw0DJQLcwIEVEG6a_YE5PDFFsKFhJzluId9F8c6HPYCKghMI9hENsEtFb2rIzLS3gC-';
const founderImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuC3qF1DeOVdr1Yn490tthq1MScxDF1ZCaZhhVvDg9YYWtX6Qb4k2SkBm8NjcUSmqj1-Ivq42NeBRSf2Zb1LFIFzndlgfwoW_AP7B99KZGDpasqhnyjwMHLkQfukj16H8s10TFwW-d7i0LM1etZR1oFsBmen5t_dzJsTcwR-Z4cCp4FITy0ESQ1L_LpoyQ_FPFL2f_slWfbjbWU_8mCrtLM7egvRuLvm8AjCD7ZrRRtOF_rVS07-0YXkg1PMM403rUVw-Kz0OwJuhe2I';
const sushiPlattersImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuD3-PzXPFDHrK-7sIXHPslX_jyh8gOUOTJ3qdph3mspni6ZujaRcd6mzRVSK7Ch13wghDqXjpOQGzQaDuRCN_ATzrycr4OHX2BtadiF9sWuCIlAABYVPPz0D93Oyb1Vd3LXb0XJfV4EDrveKkkitZHqb-JE7Y-rjLiG_f3R-Z6Sjr9vvWzAtiOSjnunbjPBkmXLogynr9pz_W8yUmNbSqN28bxqyi9MN3Str25fzZYH6nGR4kVDw4hfY4fc2NGdnMTpQbTXtKnCqYz6';
const slidersImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuDqc03tOLqXYLAiA12OUL6nFOtB6zmkqE_HBJnVKo59ITpY7N5V6yXf8UfUpsVorsjIVnfnIV6QzyAxqbFLhpooDhzBMV60TwnBDhmjAMRyGLHRhWC3kofQ032kazIN1Sv2CjbIq1eN1oof7N9KHWi5-AOCjA_cC1clI6K1o1n3yeiyLsVVwkaLOWfuiHV6CNajb5Exr4RveoXD8Lf1S4dVieHTb9nFz1wN44JA0RgJGgdPv8puwprrASUS-ofgLFbq5Ghm4kASTT03';
---

<Layout title="About | On A Roll Sushi & Sliders">
  <Nav />

  <!-- ===== SECTION 1: HERO ===== -->
  <section class="relative h-[90vh] flex items-end overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img
        src={heroImage}
        alt="On A Roll restaurant"
        class="w-full h-full object-cover"
      />
    </div>
    <!-- Hero Scrim -->
    <div class="hero-scrim absolute inset-0"></div>
    <!-- Content -->
    <div class="relative z-10 w-full px-4 md:px-8 pb-20 max-w-screen-2xl mx-auto">
      <h1 class="font-headline font-black uppercase leading-none tracking-tighter text-on-surface text-glow" style="font-size: clamp(5rem, 16vw, 16rem);">
        ABOUT<span class="text-primary">.</span>
      </h1>
      <p class="text-secondary font-label text-sm md:text-base tracking-[0.3em] uppercase mt-4 max-w-md">
        Locally Owned &amp; Family Operated — Windsor, ON
      </p>
    </div>
  </section>

  <!-- ===== SECTION 2: OUR STORY ===== -->
  <section class="py-32 bg-surface-container-low animate-on-scroll">
    <div class="px-4 md:px-8 max-w-screen-2xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">

        <!-- Image side — 6 cols -->
        <div class="lg:col-span-6">
          <div class="aspect-[4/5] w-full overflow-hidden">
            <img
              src={founderImage}
              alt="On A Roll founder and restaurant"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
            />
          </div>
        </div>

        <!-- Text side — 5 cols offset -->
        <div class="lg:col-span-5 lg:col-start-8 space-y-8">
          <span class="text-primary uppercase tracking-[0.3em] font-bold text-xs">Locally Owned &amp; Family Operated</span>
          <h2 class="text-5xl md:text-6xl font-headline font-black uppercase leading-none">
            Our Story
          </h2>
          <p class="text-secondary font-light leading-relaxed">
            Born in Windsor in 2017, On A Roll is more than a restaurant — it's a vibe. We took two things nobody thought to combine — premium sushi and gourmet sliders — and made them inseparable.
          </p>
          <p class="text-secondary font-light leading-relaxed">
            Add live music, handcrafted cocktails, and a room that pulses with energy, and you have something the city had never seen before. From day one, our mission has been simple: bring people together over food that surprises them, in a space that feels alive.
          </p>
          <p class="text-secondary font-light leading-relaxed">
            We're proud to be locally owned and operated — rooted in Windsor, built for Windsor, and grateful every night for the community that keeps rolling with us.
          </p>
          <div class="flex items-center gap-4 pt-4">
            <div class="w-12 h-[2px] bg-primary"></div>
            <span class="text-primary font-headline font-bold uppercase tracking-widest text-sm">Est. {siteInfo.established}</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== SECTION 3: INTRO — WHO KNEW ===== -->
  <section class="py-32 animate-on-scroll">
    <div class="px-4 md:px-8 max-w-screen-2xl mx-auto text-center space-y-8">
      <span class="text-primary uppercase tracking-[0.3em] font-bold text-xs">The Concept</span>
      <h2 class="font-headline font-black uppercase leading-none tracking-tighter text-on-surface" style="font-size: clamp(2rem, 6vw, 6rem);">
        Who Knew Sushi &amp; Sliders<br/>Went So Well Together?
      </h2>
      <p class="text-secondary font-light leading-relaxed max-w-2xl mx-auto text-lg">
        We did. On A Roll was built on the idea that the best nights out shouldn't force a choice. Whether you're deep in a specialty roll or biting into a smash burger slider, you're in the right place. The vibe is electric, the playlist is curated, and every dish is made to be shared — or savoured solo. No rules. Just good food, good music, and good people.
      </p>
    </div>
  </section>

  <!-- ===== SECTION 4: OUR CRAFT ===== -->
  <section class="py-32 bg-surface-container-low animate-on-scroll">
    <div class="px-4 md:px-8 max-w-screen-2xl mx-auto">

      <div class="mb-16">
        <span class="text-primary uppercase tracking-[0.3em] font-bold text-xs">Craft</span>
        <h2 class="text-5xl md:text-6xl font-headline font-black uppercase leading-none mt-4">Our Craft</h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">

        <!-- Sushi Platter — 7 cols -->
        <div class="lg:col-span-7 relative group">
          <div class="aspect-[4/3] w-full overflow-hidden">
            <img
              src={sushiPlattersImage}
              alt="Specialty sushi platter"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
          </div>
          <!-- Numbered overlay -->
          <div class="absolute top-6 left-6 w-14 h-14 border border-primary flex items-center justify-center">
            <span class="text-primary font-headline font-black text-xl">01</span>
          </div>
          <div class="mt-6 space-y-2">
            <h3 class="text-2xl font-headline font-black uppercase">The Rolls</h3>
            <p class="text-secondary font-light leading-relaxed max-w-md">
              Over 40 specialty and classic rolls, crafted fresh daily with premium fish and inventive flavour combinations.
            </p>
          </div>
        </div>

        <!-- Sliders — 4 cols, offset down -->
        <div class="lg:col-span-4 lg:col-start-9 lg:mt-24 relative group">
          <div class="aspect-[3/4] w-full overflow-hidden">
            <img
              src={slidersImage}
              alt="Gourmet fusion sliders"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
          </div>
          <!-- Numbered overlay -->
          <div class="absolute top-6 left-6 w-14 h-14 border border-primary flex items-center justify-center">
            <span class="text-primary font-headline font-black text-xl">02</span>
          </div>
          <div class="mt-6 space-y-2">
            <h3 class="text-2xl font-headline font-black uppercase">The Sliders</h3>
            <p class="text-secondary font-light leading-relaxed">
              10 slider varieties — from wagyu smash to lobster roll — served in threes and built to pair.
            </p>
          </div>
        </div>

      </div>

      <!-- Floating detail card -->
      <div class="mt-16 lg:mt-0 lg:absolute lg:bottom-8 lg:right-8 bg-surface-container-lowest p-8 space-y-4 max-w-xs relative">
        <p class="text-primary font-headline font-black text-5xl leading-none">{siteInfo.established}</p>
        <p class="text-xs font-label uppercase tracking-[0.3em] text-secondary">Established in Windsor</p>
        <div class="border-t border-outline-variant/40 pt-4 space-y-2">
          <p class="text-on-surface font-bold text-sm">120+ Menu Items</p>
          <p class="text-secondary text-xs font-light">Locally Owned &amp; Family Operated</p>
        </div>
      </div>

    </div>
  </section>

  <!-- ===== SECTION 5: CTA ===== -->
  <section class="py-40 animate-on-scroll overflow-hidden">
    <div class="px-4 md:px-8 max-w-screen-2xl mx-auto text-center space-y-12">
      <h2 class="font-headline font-black uppercase leading-none tracking-tighter text-on-surface text-glow" style="font-size: clamp(3rem, 10vw, 10rem);">
        TASTE THE<br/><span class="text-primary">REVOLUTION.</span>
      </h2>
      <div>
        <a
          href="/menu"
          class="inline-flex items-center gap-3 bg-primary text-on-primary font-headline font-bold uppercase tracking-widest text-sm px-10 py-5 hover:bg-primary-container transition-colors duration-300"
        >
          View Our Menu
          <span class="material-symbols-outlined text-base">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
