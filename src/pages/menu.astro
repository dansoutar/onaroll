---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import MenuItem from '../components/MenuItem.astro';
import MenuSection from '../components/MenuSection.astro';
import foodMenu from '../data/food-menu.json';
import drinkMenu from '../data/drink-menu.json';

const menuHeroImage = '/images/rolls-closeup.jpg';
const chefImage = '/images/sushi-platter-full.jpg';
const slidersImage = '/images/beer-sliders.jpeg';
---

<Layout title="Menu | On A Roll Sushi & Sliders">
  <Nav />

  <!-- Hero Section -->
  <header class="relative h-[460px] w-full flex items-end overflow-hidden">
    <img alt="Luxury Sushi Platter" class="absolute inset-0 w-full h-full object-cover grayscale-[20%]" src={menuHeroImage} />
    <div class="absolute inset-0 hero-scrim"></div>
    <div class="relative w-full max-w-screen-2xl mx-auto px-8 pb-16">
      <h1 class="text-7xl md:text-9xl font-headline font-black tracking-tighter text-on-background uppercase">
        OUR MENU
      </h1>
    </div>
  </header>

  <!-- Tab Navigation -->
  <section class="sticky top-[72px] md:top-[88px] z-40 bg-surface/80 backdrop-blur-xl border-b border-outline-variant/10">
    <div class="max-w-screen-2xl mx-auto px-8 overflow-x-auto">
      <nav id="menu-tabs" class="flex space-x-8 md:space-x-12 py-4 md:py-8 min-w-max">
        <a class="menu-tab text-secondary hover:text-primary font-headline font-bold uppercase tracking-widest text-sm transition-colors pb-1" href="#sushi">Sushi</a>
        <a class="menu-tab text-secondary hover:text-primary font-headline font-bold uppercase tracking-widest text-sm transition-colors pb-1" href="#sliders">Sliders</a>
        <a class="menu-tab text-secondary hover:text-primary font-headline font-bold uppercase tracking-widest text-sm transition-colors pb-1" href="#appetizers">Appetizers</a>
        <a class="menu-tab text-secondary hover:text-primary font-headline font-bold uppercase tracking-widest text-sm transition-colors pb-1" href="#cocktails">Cocktails</a>
        <a class="menu-tab text-secondary hover:text-primary font-headline font-bold uppercase tracking-widest text-sm transition-colors pb-1" href="#drinks">Wine &amp; Beer</a>
      </nav>
    </div>
  </section>

  <main class="max-w-screen-2xl mx-auto px-8 py-12 md:py-24 space-y-16 md:space-y-32">

    <!-- Sushi Section -->
    <section class="grid grid-cols-1 lg:grid-cols-12 gap-12 md:gap-20" id="sushi">
      <div class="lg:col-span-4 space-y-8">
        <span class="text-primary uppercase tracking-[0.3em] font-bold text-xs">Section 01</span>
        <h2 class="text-5xl font-headline font-black uppercase leading-none">The Artisan<br/>Sushi Rolls</h2>
        <p class="text-secondary font-light leading-relaxed max-w-sm">
          Served a la carte, 8-10 pieces. Every roll named after a classic rock legend. Ask to make any roll spicy.
        </p>
        <div class="aspect-[3/4] w-full bg-surface-container-low overflow-hidden">
          <img alt="Chef preparing sushi" class="w-full h-full object-cover opacity-80 hover:scale-105 transition-transform duration-700" src={chefImage} />
        </div>
      </div>
      <div class="lg:col-span-8 space-y-12 pt-12">
        <h3 class="text-2xl font-headline font-bold uppercase tracking-tight text-primary">Specialty Rolls</h3>
        <div class="space-y-16">
          {foodMenu.specialtyRolls.map((item) => (
            <MenuItem name={item.name} price={item.price} description={item.description} spicy={item.spicy} />
          ))}
        </div>

        <div class="w-full h-[1px] bg-outline-variant/20 my-16"></div>

        <h3 class="text-2xl font-headline font-bold uppercase tracking-tight text-primary">Veggie Rolls</h3>
        <div class="space-y-16">
          {foodMenu.veggieRolls.map((item) => (
            <MenuItem name={item.name} price={item.price} description={item.description} />
          ))}
        </div>

        <div class="w-full h-[1px] bg-outline-variant/20 my-16"></div>

        <h3 class="text-2xl font-headline font-bold uppercase tracking-tight text-primary">Small Rolls</h3>
        <div class="space-y-16">
          {foodMenu.smallRolls.map((item) => (
            <MenuItem name={item.name} price={item.price} description={item.description} />
          ))}
        </div>

        <div class="w-full h-[1px] bg-outline-variant/20 my-16"></div>

        <h3 class="text-2xl font-headline font-bold uppercase tracking-tight text-primary">Nigiri <span class="text-secondary font-light text-sm">(2 pieces)</span></h3>
        <div class="space-y-16">
          {foodMenu.nigiri.map((item) => (
            <MenuItem name={item.name} price={item.price} />
          ))}
        </div>

        <div class="w-full h-[1px] bg-outline-variant/20 my-16"></div>

        <h3 class="text-2xl font-headline font-bold uppercase tracking-tight text-primary">Sashimi <span class="text-secondary font-light text-sm">(3 pieces)</span></h3>
        <div class="space-y-16">
          {foodMenu.sashimi.map((item) => (
            <MenuItem name={item.name} price={item.price} />
          ))}
        </div>
      </div>
    </section>

    <!-- Sliders Section (Asymmetric Image Swap — reversed) -->
    <section class="grid grid-cols-1 lg:grid-cols-12 gap-12 md:gap-20 items-start" id="sliders">
      <div class="lg:col-span-8 order-2 lg:order-1 space-y-16 pt-12">
        <div class="space-y-16">
          {foodMenu.sliders.map((item) => (
            <MenuItem name={item.name} price={item.price} description={item.description} spicy={item.spicy} />
          ))}
        </div>
      </div>
      <div class="lg:col-span-4 order-1 lg:order-2 space-y-8">
        <span class="text-primary uppercase tracking-[0.3em] font-bold text-xs">Section 02</span>
        <h2 class="text-5xl font-headline font-black uppercase leading-none text-right lg:text-left">Signature<br/>Sliders</h2>
        <p class="text-secondary font-light leading-relaxed max-w-sm">$7 each or 3 for $18. Every slider is a study in texture and bold flavor.</p>
        <div class="aspect-[3/4] w-full bg-surface-container-low overflow-hidden">
          <img alt="Gourmet Sliders" class="w-full h-full object-cover opacity-80 hover:scale-105 transition-transform duration-700" src={slidersImage} />
        </div>
      </div>
    </section>

    <!-- Appetizers Section -->
    <section id="appetizers">
      <div class="mb-12">
        <span class="text-primary uppercase tracking-[0.3em] font-bold text-xs">Starters</span>
        <h2 class="text-5xl font-headline font-black uppercase leading-none mt-4">Appetizers</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
        {foodMenu.appetizers.map((item) => (
          <MenuItem name={item.name} price={item.price} description={item.description} />
        ))}
      </div>
    </section>

    <!-- Cocktails Section (Editorial Centered) -->
    <section class="bg-surface-container-low p-6 md:p-24" id="cocktails">
      <div class="max-w-4xl mx-auto space-y-12 md:space-y-24">
        <div class="text-center space-y-6">
          <span class="text-primary uppercase tracking-[0.4em] font-bold text-xs">Section 03</span>
          <h2 class="text-6xl font-headline font-black uppercase tracking-tighter">The Mixology</h2>
          <p class="text-secondary font-light max-w-md mx-auto">All crafted with 1.5oz of liquor. Hand-crafted cocktails perfected by our innovative bartenders.</p>
        </div>
        <div class="grid grid-cols-1 gap-12 md:gap-20">
          {drinkMenu.cocktails.map((item) => (
            <div class="group flex flex-col items-center text-center">
              <h3 class="text-3xl font-headline font-bold uppercase tracking-wide group-hover:text-primary transition-colors mb-2">{item.name}</h3>
              <span class="text-primary font-headline text-xl mb-6">${item.price}</span>
              <p class="text-on-surface-variant font-light max-w-lg leading-relaxed">{item.description}</p>
              {item.note && <p class="text-outline text-sm font-label italic mt-2">{item.note}</p>}
              <div class="w-12 h-[1px] bg-outline-variant/30 mt-8"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Wine & Beer Section -->
    <section id="drinks" class="space-y-24">
      <div class="mb-12">
        <span class="text-primary uppercase tracking-[0.3em] font-bold text-xs">Section 04</span>
        <h2 class="text-5xl font-headline font-black uppercase leading-none mt-4">Wine &amp; Beer</h2>
      </div>

      <!-- White Wine -->
      <div>
        <h3 class="text-2xl font-headline font-bold uppercase tracking-tight text-primary mb-8">White Wine</h3>
        <div class="space-y-12">
          {drinkMenu.wine.white.map((item) => (
            <MenuItem name={item.name} price={item.price} bottle={item.bottle} description={item.description} />
          ))}
        </div>
      </div>

      <!-- Red Wine -->
      <div>
        <h3 class="text-2xl font-headline font-bold uppercase tracking-tight text-primary mb-2">Red Wine</h3>
        <p class="text-outline text-sm font-label italic mb-8">Wine subject to tax</p>
        <div class="space-y-12">
          {drinkMenu.wine.red.map((item) => (
            <MenuItem name={item.name} price={item.price} bottle={item.bottle} description={item.description} />
          ))}
        </div>
      </div>

      <!-- Sake -->
      <div>
        <h3 class="text-2xl font-headline font-bold uppercase tracking-tight text-primary mb-8">Sake</h3>
        <div class="space-y-12">
          {drinkMenu.sake.map((item) => (
            <MenuItem name={item.name} price={item.price} />
          ))}
        </div>
      </div>

      <!-- Premium Bottles -->
      <div>
        <h3 class="text-2xl font-headline font-bold uppercase tracking-tight text-primary mb-8">Premium Bottles</h3>
        <div class="space-y-12">
          {drinkMenu.beer.premium.map((item) => (
            <MenuItem name={item.name} price={item.price} />
          ))}
        </div>
      </div>

      <!-- Domestic Bottles -->
      <div>
        <h3 class="text-2xl font-headline font-bold uppercase tracking-tight text-primary mb-8">Domestic Bottles</h3>
        <div class="space-y-12">
          {drinkMenu.beer.domestic.map((item) => (
            <MenuItem name={item.name} price={item.price} />
          ))}
        </div>
      </div>

      <!-- On Tap -->
      <div>
        <h3 class="text-2xl font-headline font-bold uppercase tracking-tight text-primary mb-8">On Tap</h3>
        <div class="space-y-12">
          {drinkMenu.beer.onTap.map((item) => (
            <MenuItem name={item.name} price={item.price} />
          ))}
        </div>
      </div>

      <!-- Tall Cans -->
      <div>
        <h3 class="text-2xl font-headline font-bold uppercase tracking-tight text-primary mb-8">Tall Cans</h3>
        <div class="space-y-12">
          {drinkMenu.beer.tallCans.map((item) => (
            <MenuItem name={item.name} price={item.price} />
          ))}
        </div>
      </div>
    </section>

  </main>

  <Footer />

  <script>
    const tabs = document.querySelectorAll<HTMLAnchorElement>('.menu-tab');
    const sectionIds = Array.from(tabs).map(tab => tab.getAttribute('href')!.slice(1));
    const sections = sectionIds.map(id => document.getElementById(id)!);

    function setActive(id: string) {
      tabs.forEach(tab => {
        tab.dataset.active = String(tab.getAttribute('href') === `#${id}`);
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
          }
        }
      },
      { rootMargin: '-20% 0px -70% 0px' }
    );

    sections.forEach(section => observer.observe(section));
    setActive(sectionIds[0]);
  </script>
</Layout>
