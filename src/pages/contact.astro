---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import siteInfo from '../data/site-info.json';

// Image from Appendix B — Contact page map
const mapImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuBrUeKdh7Jp35r5NUWVw1Z37MdA_atCMMHbrnMlvEJZHwGGYR3myXoSRrcl6QpJ-CXu_vA16AR6OxM6lJcJNmKL52ZAjaXKnKGriHTYlAC_Nd2LG3FTgJTYi0SBHf5RpyMtWragm8vtZEWs5DNk01n-v3AlW_WlFibPlnBeV26tWL1YVP2CTDZdCDJJVUnkTrVyRbkQb7sNz_u-IFjVe6bwJtTyL07VijVNhG2t_oAKszFv_bNmh-Vur1qEMvVvGAKCzNeecT8Fbaai';

const days = ['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'] as const;
type Day = typeof days[number];
---

<Layout title="Contact | On A Roll Sushi & Sliders">
  <Nav />

  <!-- ===== SECTION 1: HERO ===== -->
  <section class="pt-48 pb-32 px-8 max-w-screen-2xl mx-auto">
    <span class="text-primary uppercase tracking-[0.3em] font-bold text-xs">Get In Touch</span>
    <h1 class="font-headline font-black uppercase leading-none tracking-tighter text-on-surface mt-4" style="font-size: clamp(3rem, 10vw, 10rem);">
      Connect with the<br/><span class="text-primary">Art of the Roll</span>
    </h1>
  </section>

  <!-- ===== SECTION 2: SPLIT LAYOUT ===== -->
  <section class="py-24 bg-surface-container-low animate-on-scroll">
    <div class="px-8 max-w-screen-2xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">

        <!-- Left Column: Info -->
        <div class="space-y-12">

          <!-- Location -->
          <div class="space-y-3">
            <div class="flex items-center gap-3 mb-4">
              <span class="material-symbols-outlined text-primary">location_on</span>
              <h3 class="font-headline font-black uppercase tracking-widest text-sm">Location</h3>
            </div>
            <p class="text-secondary font-light leading-relaxed pl-9">{siteInfo.address}</p>
          </div>

          <!-- Contact -->
          <div class="space-y-3">
            <div class="flex items-center gap-3 mb-4">
              <span class="material-symbols-outlined text-primary">phone</span>
              <h3 class="font-headline font-black uppercase tracking-widest text-sm">Phone</h3>
            </div>
            <p class="text-secondary font-light pl-9">
              <a href={`tel:${siteInfo.phone}`} class="hover:text-primary transition-colors">{siteInfo.phone}</a>
            </p>
            <div class="flex items-center gap-3 mt-6 mb-4">
              <span class="material-symbols-outlined text-primary">mail</span>
              <h3 class="font-headline font-black uppercase tracking-widest text-sm">Email</h3>
            </div>
            <p class="text-secondary font-light pl-9">
              <a href={`mailto:${siteInfo.email}`} class="hover:text-primary transition-colors">{siteInfo.email}</a>
            </p>
          </div>

          <!-- Hours -->
          <div class="space-y-4">
            <div class="flex items-center gap-3 mb-6">
              <span class="material-symbols-outlined text-primary">schedule</span>
              <h3 class="font-headline font-black uppercase tracking-widest text-sm">Hours</h3>
            </div>

            <!-- Bar Hours -->
            <div class="pl-9">
              <p class="text-primary font-headline font-bold uppercase tracking-widest text-xs mb-3">Bar</p>
              <div class="space-y-2">
                {days.map((day) => (
                  <div class="flex justify-between items-center border-b border-outline-variant/20 pb-2">
                    <span class="text-secondary text-sm capitalize font-medium">{day}</span>
                    <span class="text-on-surface text-sm">{siteInfo.hours.bar[day as Day]}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- Kitchen Hours -->
            <div class="pl-9 mt-8">
              <p class="text-primary font-headline font-bold uppercase tracking-widest text-xs mb-3">Kitchen</p>
              <div class="space-y-2">
                {days.map((day) => (
                  <div class="flex justify-between items-center border-b border-outline-variant/20 pb-2">
                    <span class="text-secondary text-sm capitalize font-medium">{day}</span>
                    <span class="text-on-surface text-sm">{siteInfo.hours.kitchen[day as Day]}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

        </div>

        <!-- Right Column: Contact Form -->
        <div>
          <form
            action="https://formspree.io/f/placeholder"
            method="POST"
            class="space-y-10"
          >
            <!-- Name -->
            <div class="contact-field">
              <label for="name" class="block text-xs font-headline font-bold uppercase tracking-[0.3em] text-secondary mb-3">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="contact-input w-full bg-transparent text-on-surface py-3 outline-none"
                placeholder="Your name"
              />
            </div>

            <!-- Email -->
            <div class="contact-field">
              <label for="email" class="block text-xs font-headline font-bold uppercase tracking-[0.3em] text-secondary mb-3">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="contact-input w-full bg-transparent text-on-surface py-3 outline-none"
                placeholder="your@email.com"
              />
            </div>

            <!-- Phone -->
            <div class="contact-field">
              <label for="phone" class="block text-xs font-headline font-bold uppercase tracking-[0.3em] text-secondary mb-3">Phone</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="contact-input w-full bg-transparent text-on-surface py-3 outline-none"
                placeholder="(226) 000-0000"
              />
            </div>

            <!-- Message -->
            <div class="contact-field">
              <label for="message" class="block text-xs font-headline font-bold uppercase tracking-[0.3em] text-secondary mb-3">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="contact-input w-full bg-transparent text-on-surface py-3 outline-none resize-none"
                placeholder="Tell us what's on your mind..."
              ></textarea>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="bg-primary text-on-primary font-headline font-bold uppercase tracking-widest text-sm px-10 py-5 hover:bg-primary-container transition-colors duration-300"
            >
              Send Message
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== SECTION 3: MAP ===== -->
  <section class="animate-on-scroll">
    <div class="relative overflow-hidden group" style="height: 60vh;">
      <img
        src={mapImage}
        alt="On A Roll location map"
        class="w-full h-full object-cover transition-all duration-700"
        style="filter: grayscale(100%);"
        onmouseover="this.style.filter='grayscale(0%)'"
        onmouseout="this.style.filter='grayscale(100%)'"
      />
      <!-- Location overlay -->
      <div class="absolute inset-0 flex items-end pointer-events-none">
        <div class="px-8 pb-10 max-w-screen-2xl mx-auto w-full">
          <div class="bg-surface-container-lowest/90 backdrop-blur-sm p-6 inline-block">
            <div class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary">location_on</span>
              <div>
                <p class="font-headline font-black uppercase text-on-surface tracking-widest text-sm">{siteInfo.name}</p>
                <p class="text-secondary text-sm font-light mt-1">{siteInfo.address}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 4: QUOTE ===== -->
  <section class="py-40 animate-on-scroll">
    <div class="px-8 max-w-screen-2xl mx-auto text-center space-y-8">
      <div class="w-12 h-[2px] bg-primary mx-auto"></div>
      <blockquote class="font-headline font-black uppercase leading-none tracking-tight text-on-surface text-glow" style="font-size: clamp(1.5rem, 4vw, 4rem);">
        "Dining is not just about the food,<br class="hidden md:block" /> it's about the choreography<br class="hidden md:block" /> of the experience."
      </blockquote>
      <div class="w-12 h-[2px] bg-primary mx-auto"></div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .contact-input {
    border-bottom: 1px solid rgba(82, 68, 59, 0.4);
    transition: border-color 0.3s ease;
  }
  .contact-input:focus {
    border-bottom-color: #ffb784;
  }
  .contact-input::placeholder {
    color: rgba(229, 226, 225, 0.3);
  }
</style>
