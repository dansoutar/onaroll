---
interface Props {
  name: string;
  price: number;
  description?: string;
  spicy?: boolean;
  note?: string;
  bottle?: number;
}

const { name, price, description, spicy = false, note, bottle } = Astro.props;

const formattedPrice = price % 1 === 0 ? `$${price}` : `$${price.toFixed(2)}`;
const formattedBottle = bottle ? (bottle % 1 === 0 ? `$${bottle}` : `$${bottle.toFixed(2)}`) : null;
---

<div class="group">
  <div class="flex items-end justify-between">
    <h3 class="text-2xl font-headline font-bold uppercase tracking-tight group-hover:text-primary transition-colors">
      {name}{spicy ? ' 🌶️' : ''}
    </h3>
    <div class="dotted-leader"></div>
    <span class="text-2xl font-headline font-medium text-primary">
      {formattedPrice}{formattedBottle && <span class="text-secondary text-lg"> / {formattedBottle}</span>}
    </span>
  </div>
  {description && <p class="mt-4 text-on-surface-variant font-light max-w-xl">{description}</p>}
  {note && <p class="mt-2 text-outline text-sm font-label italic">{note}</p>}
</div>
