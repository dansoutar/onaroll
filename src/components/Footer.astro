---
import siteInfo from '../data/site-info.json';
---

<footer class="bg-[#0e0e0e] w-full pt-24 pb-12">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-12 px-8 max-w-screen-2xl mx-auto">
    <div class="md:col-span-1">
      <a href="/" class="text-xl font-bold text-[#ffb784] mb-8 block font-body uppercase tracking-widest">ON A ROLL</a>
      <p class="text-[#c8c6c5] font-body text-sm tracking-wide leading-relaxed mb-8">
        The intersection of high-fidelity sound and culinary excellence. Good Food. Good Music. Good People. Good Vibes.
      </p>
      <div class="flex gap-4">
        <a href={siteInfo.social.facebook} target="_blank" rel="noopener noreferrer" class="text-[#c8c6c5] hover:text-[#ffb784] transition-colors text-sm">Facebook</a>
        <a href={siteInfo.social.instagram} target="_blank" rel="noopener noreferrer" class="text-[#c8c6c5] hover:text-[#ffb784] transition-colors text-sm">Instagram</a>
      </div>
    </div>
    <div class="space-y-4">
      <h4 class="text-white font-bold text-sm tracking-widest uppercase mb-6">Explore</h4>
      <a class="block text-[#c8c6c5] hover:text-white transition-colors duration-300 font-body text-sm" href="/menu">Menu</a>
      <a class="block text-[#c8c6c5] hover:text-white transition-colors duration-300 font-body text-sm" href="/about">About</a>
      <a class="block text-[#c8c6c5] hover:text-white transition-colors duration-300 font-body text-sm" href="/contact">Contact</a>
      <a class="block text-[#c8c6c5] hover:text-white transition-colors duration-300 font-body text-sm" href={siteInfo.orderOnline} target="_blank" rel="noopener noreferrer">Order Online</a>
    </div>
    <div class="space-y-4">
      <h4 class="text-white font-bold text-sm tracking-widest uppercase mb-6">Contact</h4>
      <p class="text-[#c8c6c5] font-body text-sm">63 Pitt St E<br />Windsor, ON N9A 1G5</p>
      <p class="text-[#c8c6c5] font-body text-sm"><a href={`mailto:${siteInfo.email}`} class="hover:text-white transition-colors">{siteInfo.email}</a></p>
      <p class="text-[#c8c6c5] font-body text-sm"><a href={`tel:${siteInfo.phone}`} class="hover:text-white transition-colors">{siteInfo.phone}</a></p>
    </div>
    <div class="space-y-4">
      <h4 class="text-white font-bold text-sm tracking-widest uppercase mb-6">Join The Vibe</h4>
      <div class="relative">
        <input class="w-full bg-transparent border-b border-outline-variant py-2 focus:outline-none focus:border-primary text-sm text-[#c8c6c5] placeholder:text-outline-variant" placeholder="Email Address" type="email" />
        <button class="absolute right-0 bottom-2 text-primary">
          <span class="material-symbols-outlined">arrow_forward</span>
        </button>
      </div>
      <div class="pt-8 flex gap-6">
        <a class="text-[#c8c6c5] hover:text-[#ffb784] transition-colors text-sm" href={siteInfo.social.instagram} target="_blank" rel="noopener noreferrer">Instagram</a>
        <a class="text-[#c8c6c5] hover:text-[#ffb784] transition-colors text-sm" href={siteInfo.social.facebook} target="_blank" rel="noopener noreferrer">Facebook</a>
      </div>
    </div>
  </div>
  <div class="max-w-screen-2xl mx-auto px-8 mt-24 pt-8 border-t border-outline-variant/10 flex flex-col md:flex-row justify-between items-center gap-4">
    <span class="text-[#c8c6c5] font-body text-xs tracking-widest">ON A ROLL. ALL RIGHTS RESERVED.</span>
    <div class="flex gap-8 text-xs tracking-widest text-outline-variant uppercase font-bold">
      <a class="hover:text-white transition-colors" href="#">Privacy</a>
      <a class="hover:text-white transition-colors" href="#">Terms</a>
    </div>
  </div>
</footer>
