---
import siteInfo from '../data/site-info.json';
---

<nav class="fixed top-0 w-full z-50 bg-transparent dark:bg-black/60 backdrop-blur-xl">
  <div class="flex justify-between items-center w-full px-8 py-6 max-w-screen-2xl mx-auto">
    <a href="/" class="text-2xl font-black tracking-widest text-primary font-headline uppercase">ON A ROLL</a>
    <div class="hidden md:flex gap-12 items-center">
      <a href="/menu" class="text-secondary hover:text-primary font-headline font-bold tracking-tighter uppercase text-sm transition-colors duration-300">Menu</a>
      <a href="/about" class="text-secondary hover:text-primary font-headline font-bold tracking-tighter uppercase text-sm transition-colors duration-300">About</a>
      <a href="/contact" class="text-secondary hover:text-primary font-headline font-bold tracking-tighter uppercase text-sm transition-colors duration-300">Contact</a>
    </div>
    <div class="flex items-center gap-4">
      <a href={siteInfo.reserveTable} target="_blank" rel="noopener noreferrer" class="hidden md:block border border-primary text-primary px-8 py-3 font-headline font-bold uppercase tracking-widest text-sm hover:bg-primary hover:text-on-primary transition-all duration-200">
        Reserve
      </a>
      <a href={siteInfo.orderOnline} target="_blank" rel="noopener noreferrer" class="hidden md:block bg-primary text-on-primary px-8 py-3 font-headline font-bold uppercase tracking-widest text-sm hover:scale-95 transition-transform duration-200">
        Order Now
      </a>
      <button id="hamburger" class="block md:hidden text-secondary" aria-label="Toggle menu">
        <span class="material-symbols-outlined text-3xl">menu</span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Nav Overlay -->
<div id="mobile-nav" class="fixed inset-0 z-40 bg-surface-container-lowest flex-col items-center justify-center hidden">
  <button id="mobile-close" class="absolute top-6 right-8 text-secondary" aria-label="Close menu">
    <span class="material-symbols-outlined text-3xl">close</span>
  </button>
  <div class="flex flex-col items-center gap-10 mt-20">
    <a href="/menu" class="mobile-nav-link text-4xl font-headline font-black uppercase tracking-tight text-secondary hover:text-primary transition-colors">Menu</a>
    <a href="/about" class="mobile-nav-link text-4xl font-headline font-black uppercase tracking-tight text-secondary hover:text-primary transition-colors">About</a>
    <a href="/contact" class="mobile-nav-link text-4xl font-headline font-black uppercase tracking-tight text-secondary hover:text-primary transition-colors">Contact</a>
    <a href={siteInfo.reserveTable} target="_blank" rel="noopener noreferrer" class="mt-8 border border-primary text-primary px-10 py-4 font-headline font-bold uppercase tracking-widest text-sm">Reserve a Table</a>
    <a href={siteInfo.orderOnline} target="_blank" rel="noopener noreferrer" class="bg-primary text-on-primary px-10 py-4 font-headline font-bold uppercase tracking-widest text-sm">Order Now</a>
  </div>
</div>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileNav = document.getElementById('mobile-nav');
  const mobileClose = document.getElementById('mobile-close');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  function openNav() {
    mobileNav?.classList.remove('hidden');
    mobileNav?.classList.add('flex');
  }

  function closeNav() {
    mobileNav?.classList.add('hidden');
    mobileNav?.classList.remove('flex');
  }

  hamburger?.addEventListener('click', openNav);
  mobileClose?.addEventListener('click', closeNav);
  mobileLinks.forEach(link => link.addEventListener('click', closeNav));
</script>
